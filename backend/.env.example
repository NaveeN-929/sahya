# Copy to .env for local development. Never commit a real .env.
DATABASE_URL=postgres://sahay:sahay@localhost:5432/sahay
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,api=debug

# Wraps per-user data-encryption keys (backend/src/crypto.rs). 32 random bytes, base64.
# Generate one with: openssl rand -base64 32
# If unset, an ephemeral key is generated per process — fine for a quick local test, but
# anything encrypted under it is unreadable after restart. Not a substitute for a real KMS
# in production (see CLAUDE.md non-negotiable #5).
SAHAY_MASTER_KEY=

# Local LLM (PRD §9.7). Requires `docker compose -f infra/docker-compose.yml up -d` and
# then `docker compose -f infra/docker-compose.yml exec ollama ollama pull llama3.2` once.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
